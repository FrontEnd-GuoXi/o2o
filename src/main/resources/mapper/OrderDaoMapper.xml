<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.o2o.dao.OrderDao">
   <resultMap id="OrderMap" type="com.o2o.entity.Order">
        <id property="orderId" column="order_id" />
       <collection  property="orderItemList" ofType="com.o2o.entity.OrderItem">
           <id property="orderItemId" column="order_item_id" />
           <result property="quantity" column="quantity" />
           <result property="productName" column="product_name"/>
           <result property="productImg" column="product_Img" />
           <result property="unitPrice" column="unit_price" />
           <result property="totalPrice" column="total_price" />
           <result property="createTime" column="create_time" />
           <association property="product" javaType="com.o2o.entity.Product">
               <result property="productId" column="product_id" />
           </association>
       </collection >
   </resultMap>

    <insert id="addOrder"
            parameterType="com.o2o.entity.Order"
    >
    INSERT INTO tb_order
    (order_id, buyer_id, shop_id, order_no, total_price, order_status, create_time, last_edit_time)
    VALUES
    (#{orderId}, #{buyer.userId}, #{shop.shopId}, #{orderNo}, #{totalPrice}, #{orderStatus}, #{createTime}, #{lastEditTime})
    </insert>

    <update id="updateOrder" parameterType="com.o2o.entity.Order">
        UPDATE tb_order
        <set>
            <if test="totalPrice != null">
                total_price = #{totalPrice},
            </if>
            <if test="orderStatus != null">
                order_status = #{orderStatus},
            </if>
            <if test="lastEditTime != null">
                last_edit_time = #{lastEditTime}
            </if>
        </set>
        WHERE order_id = #{orderId}
    </update>

    <insert id="addOrderItem" parameterType="java.util.List">
        INSERT INTO tb_order_item
        (order_id, product_id, product_name, unit_price, quantity, total_price, create_time)
        VALUES
        <foreach collection="orderItemList" item="orderItem" separator=",">
            (#{orderItem.order.orderId}, #{orderItem.product.productId},
             #{orderItem.product.productName}, #{orderItem.unitPrice}, #{orderItem.quantity},
             #{orderItem.totalPrice}, #{orderItem.createTime})
        </foreach>
    </insert>

    <update id="updateOrderItem" parameterType="java.util.List">
        UPDATE tb_order_item
        <trim prefix="SET" suffixOverrides=",">
            <trim prefix="quantity = CASE order_item_id" suffix="END,">
                <foreach collection="orderItemList" item="orderItem">
                    WHEN #{orderItem.orderItemId} THEN #{orderItem.quantity}
                </foreach>
            </trim>
            <trim prefix="total_price = CASE order_item_id" suffix="END,">
                <foreach collection="orderItemList" item="orderItem">
                    WHEN #{orderItem.orderItemId} THEN #{orderItem.totalPrice}
                </foreach>
            </trim>
        </trim>
        WHERE order_item_id IN
          <foreach collection="orderItemList" item="orderItem" open="(" separator="," close=")">
              #{orderItem.orderItemId}
          </foreach>
    </update>


    <!-- 库存锁定-->
    <update id="orderLocking" parameterType="java.util.List">
        UPDATE tb_product
        <trim prefix="SET" suffixOverrides=",">
            <trim prefix="product_locked_number = product_locked_number + CASE product_id" suffix="END,">
                <foreach collection="orderItemList" item="orderItem">
                    WHEN #{orderItem.product.productId} THEN #{orderItem.quantity}
                </foreach>
            </trim>
            <trim prefix="product_number = product_number - CASE product_id" suffix="END,">
                <foreach collection="orderItemList" item="orderItem">
                    WHEN #{orderItem.product.productId} THEN #{orderItem.quantity}
                </foreach>
            </trim>
        </trim>
        WHERE product_id IN
              <foreach collection="orderItemList" item="orderItem" open="(" separator="," close=")">
                  #{orderItem.product.productId}
              </foreach>
        <!-- 注意：这里很难再写 "product_number - quantity > 0" 的校验，
               因为每个商品的 quantity 不一样。通常建议在业务层校验，
               或者依赖数据库的 "product_number >= 0" 约束 -->
    </update>

    <!-- 支付成功，扣减库存-->
    <update id="inventoryDeduction" parameterType="java.util.List">
        UPDATE tb_product
        <trim prefix="SET" suffixOverrides=",">
            <trim prefix="product_locked_number = product_locked_number - CASE product_id" suffix="END,">
                <foreach collection="orderItemList" item="orderItem">
                    WHEN #{orderItem.product.productId} THEN #{orderItem.quantity}
                </foreach>
            </trim>
            <trim prefix="sales_volume = sales_volume + CASE product_id" suffix="END,">
                <foreach collection="orderItemList" item="orderItem">
                    WHEN #{orderItem.product.productId} THEN #{orderItem.quantity}
                </foreach>
            </trim>
        </trim>
        WHERE product_id IN
        <foreach collection="orderItemList" item="orderItem" open="(" separator="," close=")">
            #{orderItem.product.productId}
        </foreach>
    </update>

    <!--订单超时，释放库存-->
    <update id="timeoutRelease" parameterType="java.util.List">
        UPDATE tb_product
        <trim prefix="SET" suffixOverrides=",">
            <trim prefix="product_locked_number = product_locked_number - CASE product_id" suffix="END,">
                <foreach collection="orderItemList" item="orderItem">
                    WHEN #{orderItem.product.productId} THEN #{orderItem.quantity}
                </foreach>
            </trim>
            <trim prefix="product_number = product_number + CASE product_id" suffix="END,">
                <foreach collection="orderItemList" item="orderItem">
                    WHEN #{orderItem.product.productId} THEN #{orderItem.quantity}
                </foreach>
            </trim>
        </trim>
        WHERE product_id IN
        <foreach collection="orderItemList" item="orderItem" separator="," open="(" close=")">
            #{orderItem.product.productId}
        </foreach>
    </update>

    <select id="queryOrderByIds" parameterType="java.util.List" resultMap="OrderMap">
        SELECT o.order_id, oi.order_item_id, oi.quantity, oi.product_id FROM tb_order o
              LEFT JOIN tb_order_item oi on o.order_id = oi.order_id
        WHERE o.order_id IN
              <foreach collection="orderIdList" item="orderId" open="(" close=")" separator=",">
                  #{orderId}
              </foreach>
    </select>
</mapper>